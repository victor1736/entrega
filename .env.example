# ===========================================================================
#  Configuración de la plataforma de eventos sísmicos
#  Copia este archivo a `.env` y ajusta los valores según tu entorno.
#  NO se incluyen credenciales en el código fuente (requisito del reto).
# ===========================================================================

# ---- Aplicación ----
APP_NAME=seismic-platform
ENVIRONMENT=development
LOG_LEVEL=INFO
# json | console
LOG_FORMAT=json

# ---- MongoDB ----
MONGO_INITDB_ROOT_USERNAME=seismic
MONGO_INITDB_ROOT_PASSWORD=seismic_secret_change_me
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=seismic
# URI completa (tiene prioridad si se define). Si se deja vacía se construye
# a partir de las variables anteriores.
MONGO_URI=

# ---- Cliente USGS ----
USGS_FEED_URL=https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_hour.geojson
USGS_TIMEOUT_SECONDS=30

# ---- Servicio de ingesta ----
# Intervalo de sondeo en segundos (el reto pide cada 3 minutos = 180s)
INGESTION_INTERVAL_SECONDS=180

# ---- Caché en memoria (segundos de TTL para respuestas de métricas) ----
CACHE_TTL_SECONDS=30

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000

# ---- Airflow ----
AIRFLOW_UID=50000
